{
  "defaults": {
    "fps": 60,
    "codec": "libx264",
    "audio_codec": "aac",
    "pixel_format": "yuv420p"
  },
  "language_to_family": {
    "en": "latin",
    "fr": "latin",
    "es": "latin",
    "ru": "cyrillic",
    "kk": "cyrillic",
    "ar": "arabic",
    "ug": "arabic",
    "uz": "latin",
    "tg": "cyrillic"
  },
  "subtitle_presets": {
    "latin": {
      "font_family": "Avenir Next",
      "font_size": 62,
      "outline": 3,
      "shadow": 1,
      "bottom_margin": 82,
      "max_lines": 2,
      "line_spacing": 1.08,
      "font_file": ""
    },
    "cyrillic": {
      "font_family": "Arial Unicode MS",
      "font_size": 60,
      "outline": 3,
      "shadow": 1,
      "bottom_margin": 82,
      "max_lines": 2,
      "line_spacing": 1.08,
      "font_file": ""
    },
    "arabic": {
      "font_family": "Geeza Pro",
      "font_size": 68,
      "outline": 2,
      "shadow": 1,
      "bottom_margin": 90,
      "max_lines": 2,
      "line_spacing": 1.15,
      "font_file": ""
    }
  },
  "filter_presets": {
    "clean": {
      "enabled": false,
      "brightness": 1.0,
      "contrast": 1.03,
      "saturation": 1.0
    },
    "industrial": {
      "enabled": true,
      "brightness": 0.99,
      "contrast": 1.08,
      "saturation": 0.94
    },
    "warm_brand": {
      "enabled": true,
      "brightness": 1.01,
      "contrast": 1.04,
      "saturation": 1.06
    }
  }
}